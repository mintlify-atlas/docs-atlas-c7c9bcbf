  "keyFeatures": [
    "Sync and async clients with identical APIs",
    "Fully typed with Pydantic v2 models",
    "SSE streaming for character chat and GenAgent",
    "Task polling with envelope.wait()",
    "Character chat with history management",
    "Image generation (text-to-image, img-to-img, upscaling)",
    "Search characters, models, and works",
    "Built on curl-cffi with HTTP/2 and HTTP/3 support"
  ],
  "publicApiSurface": [
